# API origin (no trailing slash). Used by Vite as import.meta.env.VITE_BACKEND_URL
# VITE_BACKEND_URL=https://bergen-pickup.preview.emergentagent.com
VITE_BACKEND_URL=http://localhost:8080

# App URL path prefix for production build (must start and end with /). Used as Vite `base`.
# Leave unset or use ./ for local dev or when the site is at the domain root.
# Example: site lives at https://example.com/testsite/ → set (leading and trailing slash):
# VITE_BASE=/testsite/